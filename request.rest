### Variables
@hostname = localhost
@port = 8080
@baseUrl = https://{{hostname}}:{{port}}

### 1. Register a new user
# This creates the user in your data.json
POST {{baseUrl}}/register
Content-Type: application/json

{
  "userName": "johndoe",
  "mail": "john@example.com",
  "password": "SecurePassword123"
}

### 2. Login to get JWT
# After running this, copy the 'accessToken' from the response
POST {{baseUrl}}/login
Content-Type: application/json

{
  "email": "john@example.com",
  "password": "SecurePassword123"
}

